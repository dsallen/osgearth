#ifndef OSGEARTHSYMBOLOGY_FILL_H
#define OSGEARTHSYMBOLOGY_FILL_H 1

#include <osgEarth/Common>
#include <osgEarth/Color>
#include <osgEarth/Config>
#include <osgEarth/Expression>

namespace osgEarth
{
    /**
     * Drawing parameters for a filled area.
     */
    class OSGEARTH_EXPORT Fill
    {
    public:
        Fill();
        Fill(const Fill& rhs);
        Fill( float r, float g, float b, float a );
        Fill( const Color& color );
        Fill(StringExpression expr);
        Fill( const Config& conf );

        virtual ~Fill() { }

        Color& color() { return _color; }
        const Color& color() const { return _color; }
        optional<StringExpression>& colorExpr() { return _expr; }
        const optional<StringExpression>& colorExpr() const { return _expr; }

    public:
        virtual Config getConfig() const;
        virtual void mergeConfig( const Config& conf );

    protected:
        Color _color;
        optional<StringExpression> _expr;
        void init();
    };
} // namespace osgEarth

OSGEARTH_SPECIALIZE_CONFIG(osgEarth::Fill);

#endif // OSGEARTHSYMBOLOGY_FILL_H
